{
  "expo": {
    "name": "مرسول",
    "slug": "marsool",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "marsool",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "مرسول — خدمة توصيل سريعة وموثوقة في سوريا. اطلب من أي مطعم وتابع طلبك لحظة بلحظة.",
    "primaryLanguage": "ar",
    "locales": {
      "ar": {
        "name": "مرسول",
        "description": "مرسول — خدمة توصيل سريعة وموثوقة في سوريا. اطلب من أي مطعم وتابع طلبك لحظة بلحظة."
      },
      "en": {
        "name": "Marsool",
        "description": "Marsool — Fast and reliable delivery service in Syria. Order from any restaurant and track your delivery in real time."
      }
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.marsool.delivery",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleLocalizations": ["ar", "en"],
        "CFBundleDevelopmentRegion": "ar"
      }
    },
    "android": {
      "package": "com.marsool.delivery",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF6B00"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B00"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج مرسول إلى موقعك لتحديد موقع التوصيل والمندوب القريب",
          "locationWhenInUsePermission": "يحتاج مرسول إلى موقعك لتحديد موقع التوصيل والمندوب القريب",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
