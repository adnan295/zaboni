# API Server Environment Variables
# Copy this file to .env and fill in the values (do NOT commit .env with real values)

# Required
JWT_SECRET=your-strong-random-secret-here
SESSION_SECRET=your-strong-random-secret-here

# Optional: WaVerify WhatsApp OTP gateway (syriasms.net)
# Get your API key from: https://syriasms.net → Dashboard → API Keys
# When set, OTPs are delivered via WhatsApp instead of SMS.
# When unset, the server falls back to local OTP generation (devCode in dev mode).
WAVERIFY_API_KEY=wa_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
